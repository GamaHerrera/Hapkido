---
const testimonials = [
  {
    name: "Josesito Aguila",
    role: "Alumno Reseña",
    content: "BUEN AMBIENTE Y EXCELENTES PROFESORES",
    rating: 5,
    image: "https://ui-avatars.com/api/?name=Josesito+Aguila&background=0D8ABC&color=fff"
  },
  {
    name: "Andrés GR",
    role: "Alumno Reseña",
    content: "Muy buena escuela y también maestros capacitados.",
    rating: 5,
    image: "https://ui-avatars.com/api/?name=Andres+GR&background=D4A034&color=fff"
  },
  {
    name: "Victor Osthmar Ruvalcaba Mendez",
    role: "Alumno Reseña",
    content: "Gran escuela, excelente profesor!",
    rating: 5,
    image: "https://ui-avatars.com/api/?name=Victor+Osthmar&background=E8420A&color=fff"
  },
  {
    name: "Maria Eugenia Maru GR",
    role: "Alumno Reseña",
    content: "Escuela certificada y afiliada con maestros capacitados",
    rating: 5,
    image: "https://ui-avatars.com/api/?name=Maria+Eugenia&background=random&color=fff"
  }
];
---

<section class="py-24 bg-zinc-950 relative overflow-hidden">
  <!-- Decorative Glow -->
  <div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
    <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[600px] h-[600px] bg-accent/30 rounded-full blur-[120px] mix-blend-screen"></div>
    <div class="absolute top-1/2 right-1/4 -translate-y-1/2 w-[600px] h-[600px] bg-energy/20 rounded-full blur-[120px] mix-blend-screen"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <span class="text-accent font-semibold tracking-widest uppercase text-sm mb-4 inline-block">Nuestra Comunidad</span>
      <h2 class="text-4xl md:text-5xl font-outfit font-bold text-white mb-6">Testimonios Reales</h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto font-light leading-relaxed">
        Descubre cómo el entrenamiento ha transformado la vida de nuestros alumnos, construyendo fuerza, confianza y disciplina.
      </p>
    </div>

    <div class="relative w-full overflow-hidden" id="testimonial-container">
      <div 
        class="flex transition-transform duration-700 ease-out" 
        id="testimonial-track"
      >
        {testimonials.map((testimonial) => (
          <div class="w-full shrink-0 px-4 md:px-12 flex justify-center">
            <div class="glass-card rounded-3xl p-10 md:p-14 max-w-3xl w-full mx-auto relative border border-white/10 shadow-[0_20px_40px_-20px_rgba(0,0,0,0.8)]">
              <!-- Quote Icon -->
              <svg class="absolute top-8 right-10 md:top-12 md:right-14 h-16 w-16 text-white/5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
              </svg>

              <!-- Stars -->
              <div class="flex mb-8">
                {[...Array(testimonial.rating)].map(() => (
                  <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>

              <!-- Quote -->
              <p class="text-xl md:text-2xl text-gray-300 font-inter font-light italic leading-relaxed mb-10 relative z-10">
                "{testimonial.content}"
              </p>

              <!-- Author -->
              <div class="flex items-center">
                <img 
                  src={testimonial.image} 
                  alt={testimonial.name} 
                  class="w-14 h-14 rounded-full object-cover border-2 border-accent shadow-lg shadow-accent/20"
                />
                <div class="ml-4">
                  <h4 class="font-outfit font-bold text-white tracking-wide">{testimonial.name}</h4>
                  <p class="text-accent text-sm uppercase tracking-widest mt-1 text-xs">{testimonial.role}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation Data Attributes -->
      <div 
        class="flex justify-center mt-12 space-x-3"
        id="testimonial-dots"
        data-count={testimonials.length}
      >
        {testimonials.map((_, i) => (
          <button 
            class={`w-2 h-2 md:w-3 md:h-3 rounded-full transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-accent ${i === 0 ? 'bg-accent w-6 md:w-10' : 'bg-gray-600 hover:bg-gray-400'}`}
            aria-label={`Ir al testimonio ${i + 1}`}
            data-index={i}
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  let autoSlideInterval: number;
    
  const setupTestimonialSlider = () => {
    const track = document.getElementById('testimonial-track') as HTMLElement;
    const dotsContainer = document.getElementById('testimonial-dots');
    
    if (!track || !dotsContainer) return;
    
    const countStr = dotsContainer.getAttribute('data-count');
    if(!countStr) return;
    const count = parseInt(countStr, 10);
    const dots = dotsContainer.querySelectorAll('button');
    let currentSlide = 0;
    
    const updateSlider = (index: number) => {
      // Bounds check
      currentSlide = (index + count) % count;
      
      // Move track
      track.style.transform = `translateX(-${currentSlide * 100}%)`;
      
      // Update dots
      dots.forEach((dot, i) => {
        if (i === currentSlide) {
          dot.className = 'w-6 md:w-10 h-2 md:h-3 rounded-full transition-all duration-500 bg-[#D4A034] focus:outline-none focus:ring-2 focus:ring-[#D4A034] shadow-[0_0_10px_#D4A034]';
        } else {
          dot.className = 'w-2 h-2 md:w-3 md:h-3 rounded-full transition-all duration-300 bg-gray-600 hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-[#D4A034]';
        }
      });
    }

    function nextSlide() {
      currentSlide = (currentSlide + 1) % count;
      updateSlider(currentSlide);
    }

    function startAutoSlide() {
      stopAutoSlide();
      autoSlideInterval = window.setInterval(nextSlide, 5000) as unknown as number;
    }

    function stopAutoSlide() {
      if (autoSlideInterval) {
        window.clearInterval(autoSlideInterval);
      }
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        const target = e.target as HTMLButtonElement;
        const idxAttr = target.getAttribute('data-index');
        const index = parseInt(idxAttr || '0', 10);
        updateSlider(index);
        startAutoSlide(); // Reset timer on manual interaction
      });
    });

    // Pause on hover
    track.addEventListener('mouseenter', stopAutoSlide);
    track.addEventListener('mouseleave', startAutoSlide);

    startAutoSlide();
  };

  setupTestimonialSlider();
  document.addEventListener('astro:page-load', setupTestimonialSlider);
</script>
