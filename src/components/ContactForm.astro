---
interface Props {
  formId?: string;
}

const { formId = "contact-form" } = Astro.props;
---

<div class="glass-card rounded-3xl overflow-hidden border border-white/5 shadow-2xl relative max-w-6xl mx-auto">
  <!-- Decorative Glow -->
  <div class="absolute -top-32 -right-32 w-[400px] h-[400px] bg-energy/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="grid grid-cols-1 md:grid-cols-5 relative z-10">
    <!-- Información de Contacto Lado Izquierdo -->
    <div class="bg-primary/50 backdrop-blur-md p-10 md:p-14 md:col-span-2 text-white flex flex-col justify-between border-b md:border-b-0 md:border-r border-white/5">
      <div>
        <h3 class="font-outfit font-bold text-3xl mb-4 tracking-wide text-white">Da el primer paso</h3>
        <p class="text-gray-400 font-light mb-12 text-sm leading-relaxed text-balance">
          Llena el formulario y obtén una clase de prueba <strong class="text-accent font-semibold">completamente gratis</strong>. Sin compromisos, sin ataduras. Descubre de lo que eres capaz.
        </p>

        <div class="space-y-8">
          <div class="flex items-start">
            <div class="bg-white/5 p-3 rounded-full mr-4 flex-shrink-0 border border-white/5">
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h4 class="font-outfit font-semibold text-lg mb-1 tracking-wide text-white">Nuestro Dojang</h4>
              <p class="text-gray-400 font-light text-sm">Emilio Carranza 98, Col. Zapopan Centro.<br />Zapopan, Jalisco. 45100</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="bg-white/5 p-3 rounded-full mr-4 flex-shrink-0 border border-white/5">
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h4 class="font-outfit font-semibold text-lg mb-1 tracking-wide text-white">Teléfono & WhatsApp</h4>
              <p class="text-gray-400 font-light text-sm">+52 33 1394 1272</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="mt-16 flex space-x-4">
        <a href="#" class="bg-white/5 hover:bg-white/10 p-3 rounded-full transition-colors border border-white/5">
          <span class="sr-only">Facebook</span>
          <svg class="h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
        </a>
        <a href="#" class="bg-white/5 hover:bg-white/10 p-3 rounded-full transition-colors border border-white/5">
          <span class="sr-only">Instagram</span>
          <svg class="h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg>
        </a>
      </div>
    </div>

    <!-- Formulario Lado Derecho -->
    <div class="bg-zinc-900/60 p-10 md:p-14 md:col-span-3">
      <form id={formId} class="space-y-6" action="#" method="POST">
        <!-- Grid de 2 columnas para Nombre y Teléfono -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-400 mb-2">Nombre Completo</label>
            <input type="text" name="name" id="name" required class="w-full bg-zinc-950 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all" placeholder="Escribe tu nombre">
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-400 mb-2">Teléfono / WhatsApp</label>
            <input type="tel" name="phone" id="phone" required class="w-full bg-zinc-950 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all" placeholder="(000) 000 0000">
          </div>
        </div>

        <div>
           <label for="email" class="block text-sm font-medium text-gray-400 mb-2">Correo Electrónico (Opcional)</label>
           <input type="email" name="email" id="email" class="w-full bg-zinc-950 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all" placeholder="tu@correo.com">
        </div>

        <div>
          <label for="interest" class="block text-sm font-medium text-gray-400 mb-2">Área de Interés</label>
          <div class="relative">
            <select id="interest" name="interest" class="w-full bg-zinc-950 border border-white/10 rounded-xl px-4 py-3 text-white appearance-none focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all">
              <option value="tkd-infantil">Taekwondo Infantil</option>
              <option value="tkd-adultos">Taekwondo Adultos</option>
              <option value="hkd-adultos">Hapkido (Defensa Personal)</option>
              <option value="duda">Tengo otra duda general</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-500">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </div>
          </div>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-400 mb-2">Mensaje o Duda</label>
          <textarea id="message" name="message" rows="4" class="w-full bg-zinc-950 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all resize-none" placeholder="¿Tienes alguna pregunta específica antes de venir?"></textarea>
        </div>

        <div class="pt-4">
          <button type="submit" class="group relative w-full flex justify-center py-4 px-4 border border-transparent rounded-xl text-sm font-outfit font-bold uppercase tracking-widest text-white bg-energy hover:bg-red-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-zinc-900 focus:ring-energy transition-all duration-300 shadow-[0_0_20px_rgba(220,38,38,0.3)] hover:shadow-[0_0_30px_rgba(220,38,38,0.5)] overflow-hidden">
            <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></span>
            <span class="relative z-10 flex items-center">
              Enviar y Agendar Clase
              <svg class="ml-2 w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </button>
        </div>
        
        <p class="text-xs text-center text-gray-500 mt-4 font-light">Tus datos están seguros con nosotros. No enviamos spam.</p>
      </form>
    </div>
  </div>
</div>

<script define:vars={{ formId }}>
  const form = document.getElementById(formId);
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('Modo Demo: Formulario enviado. ¡Gracias!');
    });
  }
</script>
